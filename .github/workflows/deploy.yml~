name: Deploy Angular 21.2 App to Apache

on:
  push:
    branches:
      - main

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      # 1. Récupération du code source
      - name: Checkout code
        uses: actions/checkout@v4

      # 2. Setup Node.js avec cache natif npm
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      # 3. Installation propre et Build de production (Esbuild/Vite)
      - name: Install dependencies and build
        run: |
          npm ci
          npm run build -- --configuration=production

      # 4. Nettoyage du répertoire web de springapp pour éviter les résidus de cache
      - name: Clean remote directory
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.VPS_HOST }}
          username: ${{ secrets.VPS_USERNAME }}
          key: ${{ secrets.VPS_SSH_KEY }}
          port: 22
          # options expérimentales si votre serveur rejette l'algo par défaut :
          fingerprint: ""
          script: |
            rm -rf /home/springapp/web/*

      # 5. Déploiement du build moderne (dist/concours/browser/*)
      - name: Deploy to VPS via SCP
        uses: appleboy/scp-action@v0.1.7
        with:
          host: ${{ secrets.VPS_HOST }}
          username: ${{ secrets.VPS_USERNAME }}
          key: ${{ secrets.VPS_SSH_KEY }}
          port: 22
          script: |
            cd /home/springapp/web
          # Si index.html n'existe pas, on cherche n'importe quel fichier HTML restant pour faire une copie
            if [ ! -f index.html ]; then
            AVAILABLE_HTML=$(ls *.html 2>/dev/null | head -n 1)
            if [ ! -z "$AVAILABLE_HTML" ]; then
            cp "$AVAILABLE_HTML" index.html
            echo "index.html créé à partir de $AVAILABLE_HTML"
            else
            echo "Aucun fichier HTML trouvé dans /home/springapp/web !"
            fi
            fi
          # On s'assure qu'Apache a bien le droit de lire le fichier créé
          chmod 644 index.html 2>/dev/null || true
          source: "dist/concours/browser/*"
          target: "/home/springapp/web"
          # strip_components: 3 retire "dist/", "concours/" et "browser/" pour ne coller QUE le contenu
          strip_components: 3 # Retire dist (1), concours (2), browser (3)
